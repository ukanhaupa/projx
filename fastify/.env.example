DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fastify_template?schema=public"

# 48+ byte secret for JWT signing/verification.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=<generate-with-above-command>

# Comma-separated allowed origins for CORS. No default — set explicitly per environment.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173

# 32-byte base64 key.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRED_ENCRYPTION_KEY=<generate-with-above-command>

# Set to true only where the OpenAPI docs UI at /docs should be reachable.
EXPOSE_API_DOCS=false
