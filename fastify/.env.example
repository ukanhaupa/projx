DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fastify_template?schema=public"
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=debug

JWT_SECRET=dev-secret-change-in-production
JWT_PROVIDER=shared_secret
JWT_PUBLIC_KEY=
JWT_JWKS_URL=

CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# Required: 32-byte base64 key for encrypting credentials in service_configs.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRED_ENCRYPTION_KEY=

# Global rate limit: max requests per window per user (or IP if anonymous).
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute
