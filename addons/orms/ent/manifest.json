{
  "name": "ent",
  "displayName": "ent",
  "frameworks": ["go"],
  "removeFromBase": [
    "internal/audit",
    "internal/apperr/errors.go",
    "internal/apperr/errors_test.go",
    "internal/apperr/middleware_test.go",
    "internal/db/client.go",
    "internal/db/client_test.go",
    "internal/entities/auto_routes.go",
    "internal/entities/auto_routes_test.go",
    "internal/entities/query.go",
    "internal/entities/query_test.go",
    "internal/entities/query_extra_test.go",
    "internal/entities/reflectutil.go",
    "internal/entities/registry.go",
    "internal/entities/registry_test.go",
    "internal/entities/types.go",
    "internal/sync/sync.go",
    "internal/sync/sync_test.go",
    "internal/serviceconfig/model.go",
    "internal/serviceconfig/serviceconfig.go",
    "internal/serviceconfig/serviceconfig_test.go",
    "internal/posts/post.go",
    "internal/posts/post_test.go",
    "internal/posts/post_integration_test.go",
    "internal/health/health.go",
    "internal/health/health_test.go",
    "main.go",
    "go.mod",
    "go.sum"
  ],
  "packageOverrides": {},
  "gomodOverrides": {
    "remove": ["gorm.io/gorm", "gorm.io/driver/postgres"],
    "add": {
      "entgo.io/ent": "v0.14.1",
      "github.com/jackc/pgx/v5": "v5.5.5",
      "github.com/lib/pq": "v1.10.9"
    }
  },
  "dockerfile": {
    "extraConfigFiles": ["ent/", "generate.go"],
    "preBuild": "go generate ./...",
    "migrateCommand": "/app -migrate"
  }
}
