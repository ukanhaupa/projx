#!/usr/bin/env bash
set -e

# ── Secret detection ──────────────────────────────────────────────
STAGED_DIFF="$(git diff --cached --diff-filter=ACMR)"

AKIA_HITS="$(echo "$STAGED_DIFF" | grep -E '(AKIA|ASIA)[A-Z0-9]{16}' | grep -vE '(pragma: allowlist secret|gitleaks:allow)' || true)"
if [ -n "$AKIA_HITS" ]; then
  echo "ERROR: Possible AWS access key detected in staged changes:"
  echo "$AKIA_HITS" | head -5
  echo "Add 'pragma: allowlist secret' on the line to whitelist if intentional."
  exit 1
fi

if echo "$STAGED_DIFF" | grep -qE '(password|secret|token)\s*[:=]\s*["\x27][^"'\'']{8,}' 2>/dev/null; then
  REAL_SECRETS="$(echo "$STAGED_DIFF" | grep -E '(password|secret|token)\s*[:=]\s*["\x27][^"'\'']{8,}' | grep -vE '(test-secret|dev-secret|example|placeholder|your-|changeme|CHANGE_ME|pragma: allowlist secret|gitleaks:allow)' || true)"
  if [ -n "$REAL_SECRETS" ]; then
    echo "WARNING: Possible secret detected in staged changes:"
    echo "$REAL_SECRETS" | head -5
    echo "Add 'pragma: allowlist secret' on the line to whitelist, or commit with --no-verify if intentional."
    exit 1
  fi
fi

STAGED_ENV_FILES="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^(\.env$|.*\/\.env$|.*\.env\.(prod|staging|dev)$)' || true)"
if [ -n "$STAGED_ENV_FILES" ]; then
  echo "ERROR: .env file(s) staged for commit:"
  echo "$STAGED_ENV_FILES"
  exit 1
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
<% for (const inst of fastapiInstances) { %>

<%= inst.upper %>_PY=$(echo "$STAGED_FILES" | grep '^<%= inst.path %>/.*\.py$' || true)
if [ -n "$<%= inst.upper %>_PY" ]; then
  echo "Running quality gates for <%= inst.path %>..."
  cd <%= inst.path %>
  echo "$<%= inst.upper %>_PY" | sed 's|^<%= inst.path %>/||' | xargs uv run ruff format
  echo "$<%= inst.upper %>_PY" | sed 's|^<%= inst.path %>/||' | xargs uv run ruff check --fix
  uv run mypy
  if grep -rEn 'from src\.[a-z_]+(\.[a-z_]+)?\._[a-z_]+ import' src/ | grep -v 'pragma:.*allow-private-import'; then
    echo "ERROR: src/ files cannot import from another module's _-prefixed file. Import from the package, or add '# pragma: allow-private-import' on the line if the cycle makes a package import impossible."
    exit 1
  fi
  uv run lint-imports
  cd ..
  echo "$<%= inst.upper %>_PY" | xargs git add
fi
<% } %>
<% for (const inst of fastifyInstances) { %>

<%= inst.upper %>_TS=$(echo "$STAGED_FILES" | grep '^<%= inst.path %>/.*\.ts$' || true)
<%= inst.upper %>_ALL=$(echo "$STAGED_FILES" | grep '^<%= inst.path %>/' || true)
if [ -n "$<%= inst.upper %>_ALL" ]; then
  echo "Formatting <%= inst.path %>..."
  cd <%= inst.path %>
  echo "$<%= inst.upper %>_ALL" | sed 's|^<%= inst.path %>/||' | xargs <%= pm.exec %> prettier --write --ignore-unknown
  if [ -n "$<%= inst.upper %>_TS" ]; then
    echo "$<%= inst.upper %>_TS" | sed 's|^<%= inst.path %>/||' | xargs <%= pm.exec %> eslint --fix
    <%= pm.exec %> tsc --noEmit
  fi
  cd ..
  echo "$<%= inst.upper %>_ALL" | xargs git add
fi
<% } %>
<% for (const inst of expressInstances) { %>

<%= inst.upper %>_TS=$(echo "$STAGED_FILES" | grep '^<%= inst.path %>/.*\.ts$' || true)
<%= inst.upper %>_ALL=$(echo "$STAGED_FILES" | grep '^<%= inst.path %>/' || true)
if [ -n "$<%= inst.upper %>_ALL" ]; then
  echo "Formatting <%= inst.path %>..."
  cd <%= inst.path %>
  echo "$<%= inst.upper %>_ALL" | sed 's|^<%= inst.path %>/||' | xargs <%= pm.exec %> prettier --write --ignore-unknown
  if [ -n "$<%= inst.upper %>_TS" ]; then
    echo "$<%= inst.upper %>_TS" | sed 's|^<%= inst.path %>/||' | xargs <%= pm.exec %> eslint --fix
    <%= pm.exec %> tsc --noEmit
  fi
  cd ..
  echo "$<%= inst.upper %>_ALL" | xargs git add
fi
<% } %>
<% for (const inst of goInstances) { %>

<%= inst.upper %>_GO=$(echo "$STAGED_FILES" | grep '^<%= inst.path %>/.*\.go$' || true)
if [ -n "$<%= inst.upper %>_GO" ]; then
  if command -v go &>/dev/null; then
    echo "Checking <%= inst.path %>..."
    cd <%= inst.path %>
    REL_FILES=$(echo "$<%= inst.upper %>_GO" | sed 's|^<%= inst.path %>/||')
    UNFORMATTED=$(echo "$REL_FILES" | xargs gofmt -l)
    if [ -n "$UNFORMATTED" ]; then
      echo "ERROR: gofmt found unformatted files in <%= inst.path %>:"
      echo "$UNFORMATTED"
      echo "Run 'gofmt -w' on these files and re-stage."
      exit 1
    fi
    go vet ./...
    if command -v golangci-lint &>/dev/null; then
      golangci-lint run ./...
    else
      echo "Skipping golangci-lint (not installed — \`brew install golangci-lint\` to enable)"
    fi
    cd ..
    echo "$<%= inst.upper %>_GO" | xargs git add
  else
    echo "Skipping <%= inst.path %> gates (go toolchain not installed)"
  fi
fi
<% } %>
<% for (const inst of rustInstances) { %>

<%= inst.upper %>_RS=$(echo "$STAGED_FILES" | grep -E '^<%= inst.path %>/.*\.rs$' || true)
if [ -n "$<%= inst.upper %>_RS" ]; then
  if command -v cargo &>/dev/null; then
    echo "Checking <%= inst.path %>..."
    cd <%= inst.path %>
    REL_RS=$(echo "$<%= inst.upper %>_RS" | sed 's|^<%= inst.path %>/||')
    echo "$REL_RS" | xargs cargo fmt --check --
    cargo clippy -- -D warnings
    cd ..
    echo "$<%= inst.upper %>_RS" | xargs git add
  else
    echo "Skipping <%= inst.path %> gates (cargo not installed)"
  fi
fi
<% } %>
<% for (const inst of laravelInstances) { %>

<%= inst.upper %>_PHP=$(echo "$STAGED_FILES" | grep -E '^<%= inst.path %>/.*\.php$' || true)
if [ -n "$<%= inst.upper %>_PHP" ]; then
  if command -v php &>/dev/null && [ -x <%= inst.path %>/vendor/bin/pint ]; then
    echo "Checking <%= inst.path %>..."
    cd <%= inst.path %>
    REL_PHP=$(echo "$<%= inst.upper %>_PHP" | sed 's|^<%= inst.path %>/||')
    echo "$REL_PHP" | xargs ./vendor/bin/pint
    ./vendor/bin/phpstan analyse --no-progress --level=8 --memory-limit=512M
    cd ..
    echo "$<%= inst.upper %>_PHP" | xargs git add
  else
    echo "Skipping <%= inst.path %> gates (php or vendor/bin/pint not available — run 'composer install' in <%= inst.path %>/)"
  fi
fi
<% } %>
<% for (const inst of vitejsInstances) { %>

<%= inst.upper %>_TS=$(echo "$STAGED_FILES" | grep '^<%= inst.path %>/.*\.tsx\?$' || true)
<%= inst.upper %>_ALL=$(echo "$STAGED_FILES" | grep '^<%= inst.path %>/' || true)
if [ -n "$<%= inst.upper %>_ALL" ]; then
  echo "Formatting <%= inst.path %>..."
  cd <%= inst.path %>
  echo "$<%= inst.upper %>_ALL" | sed 's|^<%= inst.path %>/||' | xargs <%= pm.exec %> prettier --write --ignore-unknown
  if [ -n "$<%= inst.upper %>_TS" ]; then
    echo "$<%= inst.upper %>_TS" | sed 's|^<%= inst.path %>/||' | xargs <%= pm.exec %> eslint --fix
    <%= pm.exec %> tsc --noEmit
  fi
  cd ..
  echo "$<%= inst.upper %>_ALL" | xargs git add
fi
<% } %>
<% for (const inst of e2eInstances) { %>

<%= inst.upper %>_TS=$(echo "$STAGED_FILES" | grep '^<%= inst.path %>/.*\.ts$' || true)
<%= inst.upper %>_ALL=$(echo "$STAGED_FILES" | grep '^<%= inst.path %>/' || true)
if [ -n "$<%= inst.upper %>_ALL" ]; then
  echo "Formatting <%= inst.path %>..."
  cd <%= inst.path %>
  echo "$<%= inst.upper %>_ALL" | sed 's|^<%= inst.path %>/||' | xargs <%= pm.exec %> prettier --write --ignore-unknown
  if [ -n "$<%= inst.upper %>_TS" ]; then
    echo "$<%= inst.upper %>_TS" | sed 's|^<%= inst.path %>/||' | xargs <%= pm.exec %> eslint --fix
    <%= pm.exec %> tsc --noEmit
  fi
  cd ..
  echo "$<%= inst.upper %>_ALL" | xargs git add
fi
<% } %>
<% for (const inst of mobileInstances) { %>

<%= inst.upper %>_DART=$(echo "$STAGED_FILES" | grep '^<%= inst.path %>/.*\.dart$' || true)
if [ -n "$<%= inst.upper %>_DART" ]; then
  if command -v dart &> /dev/null; then
    echo "Formatting <%= inst.path %>..."
    cd <%= inst.path %>
    echo "$<%= inst.upper %>_DART" | sed 's|^<%= inst.path %>/||' | xargs dart format
    if command -v flutter &> /dev/null; then
      dart analyze --fatal-infos
    fi
    cd ..
    echo "$<%= inst.upper %>_DART" | xargs git add
  else
    echo "Skipping mobile lint (dart not installed)"
  fi
fi
<% } %>
<% for (const inst of infraInstances) { %>

<%= inst.upper %>_TF=$(echo "$STAGED_FILES" | grep '^<%= inst.path %>/.*\.tf$' || true)
if [ -n "$<%= inst.upper %>_TF" ]; then
  if command -v terraform &> /dev/null; then
    echo "Checking <%= inst.path %>..."
    cd <%= inst.path %>/stack
    echo "$<%= inst.upper %>_TF" | sed 's|^<%= inst.path %>/stack/||' | xargs terraform fmt
    [ -d .terraform ] || terraform init -backend=false -input=false >/dev/null
    terraform validate
    if command -v tflint &> /dev/null; then
      tflint --recursive
    else
      echo "Skipping tflint (not installed)"
    fi
    if command -v trivy &> /dev/null; then
      trivy config --exit-code 1 --severity HIGH,CRITICAL .
    else
      echo "Skipping trivy config scan (not installed)"
    fi
    cd ../..
    echo "$<%= inst.upper %>_TF" | xargs git add
  else
    echo "Skipping infra lint (terraform not installed)"
  fi
fi
<% } %>
<% for (const inst of adminPanelInstances) { %>

<%= inst.upper %>_GO=$(echo "$STAGED_FILES" | grep '^<%= inst.path %>/.*\.go$' || true)
if [ -n "$<%= inst.upper %>_GO" ]; then
  if command -v go &> /dev/null; then
    echo "Checking <%= inst.path %>..."
    echo "$<%= inst.upper %>_GO" | sed 's|^<%= inst.path %>/||' | (cd <%= inst.path %> && xargs gofmt -w)
    (cd <%= inst.path %> && go vet ./...)
    echo "$<%= inst.upper %>_GO" | xargs git add
  else
    echo "Skipping <%= inst.path %> checks (go not installed)"
  fi
fi
<% } %>
