services:
<% if (components.includes('fastapi')) { %>
  migrate:
    build: ./<%= paths.fastapi %>
    command: ['uv', 'run', 'migrate.py']
    env_file:
      - ./<%= paths.fastapi %>/.env
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: '0.5'
    networks:
      - app-network

  backend:
    build: ./<%= paths.fastapi %>
    expose:
      - '7860'
    env_file:
      - ./<%= paths.fastapi %>/.env
    restart: unless-stopped
    depends_on:
      migrate:
        condition: service_completed_successfully
    healthcheck:
      test:
        [
          'CMD',
          'python',
          '-c',
          "import urllib.request; urllib.request.urlopen('http://localhost:7860/api/health')",
        ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: '1.0'
        reservations:
          memory: 256M
    security_opt:
      - no-new-privileges:true
    read_only: true
    tmpfs:
      - /tmp
    networks:
      - app-network
<% } %>
<% if (components.includes('fastify')) { %>
  backend-fastify:
    build: ./<%= paths.fastify %>
    expose:
      - '3000'
    env_file:
      - ./<%= paths.fastify %>/.env
    restart: unless-stopped
    healthcheck:
      test: ['CMD', 'wget', '--spider', '-q', 'http://localhost:3000/api/health']
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: '1.0'
    security_opt:
      - no-new-privileges:true
    networks:
      - app-network
<% } %>
<% if (components.includes('frontend')) { %>
  frontend:
    build:
      context: ./<%= paths.frontend %>
      args:
        VITE_API_URL: ''
    ports:
      - '80:80'
      - '443:443'
    environment:
      - DOMAIN=${DOMAIN:-localhost}
    volumes:
      - letsencrypt:/etc/letsencrypt
      - certbot-www:/var/www/certbot
<% if (components.includes('fastapi')) { %>
    depends_on:
      backend:
        condition: service_healthy
<% } %>
<% if (components.includes('fastify') && !components.includes('fastapi')) { %>
    depends_on:
      backend-fastify:
        condition: service_healthy
<% } %>
    restart: unless-stopped
    healthcheck:
      test: ['CMD', 'wget', '--spider', '-q', 'http://localhost:80/']
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
    deploy:
      resources:
        limits:
          memory: 128M
          cpus: '0.5'
    security_opt:
      - no-new-privileges:true
    networks:
      - app-network

  certbot:
    image: certbot/certbot:latest
    volumes:
      - letsencrypt:/etc/letsencrypt
      - certbot-www:/var/www/certbot
    entrypoint: /bin/sh -c "trap exit TERM; while :; do certbot renew --quiet; sleep 12h & wait $${!}; done"
    restart: unless-stopped
    depends_on:
      frontend:
        condition: service_healthy
    profiles:
      - ssl
    deploy:
      resources:
        limits:
          memory: 64M
          cpus: '0.25'
    networks:
      - app-network
<% } %>
<% if (components.includes('frontend')) { %>
volumes:
  letsencrypt:
  certbot-www:
<% } %>

networks:
  app-network:
    driver: bridge
