services:
<% for (const inst of fastapiInstances) { %>
  <%= inst.path %>-migrate:
    build: ./<%= inst.path %>
    command: ["uv", "run", "migrate.py"]
    env_file:
      - ./<%= inst.path %>/.env
    networks:
      - app-network
  <%= inst.path %>:
    build: ./<%= inst.path %>
    expose:
      - "7860"
    env_file:
      - ./<%= inst.path %>/.env
    restart: unless-stopped
    depends_on:
      <%= inst.path %>-migrate:
        condition: service_completed_successfully
    healthcheck:
      test:
        [
          "CMD",
          "python",
          "-c",
          "import urllib.request; urllib.request.urlopen('http://localhost:7860/api/health/live')",
        ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    networks:
      app-network:
<% if (fastifyInstances.length === 0 && expressInstances.length === 0 && inst.path === fastapiInstances[0].path) { %>
        aliases:
          - backend
<% } %>
<% } %>
<% for (const inst of fastifyInstances) { %>
  <%= inst.path %>-migrate:
    build:
      context: ./<%= inst.path %>
      target: migrate
    env_file:
      - ./<%= inst.path %>/.env
    networks:
      - app-network
  <%= inst.path %>:
    build: ./<%= inst.path %>
    expose:
      - "3000"
    env_file:
      - ./<%= inst.path %>/.env
    restart: unless-stopped
    depends_on:
      <%= inst.path %>-migrate:
        condition: service_completed_successfully
    healthcheck:
      test:
        [
          "CMD",
          "node",
          "-e",
          "require('http').get('http://localhost:3000/api/health/live', r => process.exit(r.statusCode === 200 ? 0 : 1)).on('error', () => process.exit(1))",
        ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    networks:
      app-network:
<% if (inst.path === fastifyInstances[0].path) { %>
        aliases:
          - backend
<% } %>
<% } %>
<% for (const inst of expressInstances) { %>
  <%= inst.path %>-migrate:
    build:
      context: ./<%= inst.path %>
      target: migrate
    env_file:
      - ./<%= inst.path %>/.env
    networks:
      - app-network
  <%= inst.path %>:
    build: ./<%= inst.path %>
    expose:
      - "3000"
    env_file:
      - ./<%= inst.path %>/.env
    restart: unless-stopped
    depends_on:
      <%= inst.path %>-migrate:
        condition: service_completed_successfully
    healthcheck:
      test:
        [
          "CMD",
          "node",
          "-e",
          "require('http').get('http://localhost:3000/api/health/live', r => process.exit(r.statusCode === 200 ? 0 : 1)).on('error', () => process.exit(1))",
        ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    networks:
      app-network:
<% if (fastifyInstances.length === 0 && inst.path === expressInstances[0].path) { %>
        aliases:
          - backend
<% } %>
<% } %>
<% for (const inst of goInstances) { %>
  <%= inst.path %>:
    build:
      context: ./<%= inst.path %>
      dockerfile: Dockerfile
    expose:
      - "8080"
    env_file:
      - ./<%= inst.path %>/.env
    restart: unless-stopped
    healthcheck:
      test:
        [
          "CMD",
          "wget",
          "-qO-",
          "http://localhost:8080/api/health",
        ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    networks:
      app-network:
<% if (fastifyInstances.length === 0 && expressInstances.length === 0 && fastapiInstances.length === 0 && inst.path === goInstances[0].path) { %>
        aliases:
          - backend
<% } %>
<% } %>
<% for (const inst of rustInstances) { %>
  <%= inst.path %>:
    build:
      context: ./<%= inst.path %>
      dockerfile: Dockerfile
    expose:
      - "8080"
    env_file:
      - ./<%= inst.path %>/.env
    restart: unless-stopped
    healthcheck:
      test:
        [
          "CMD",
          "wget",
          "-qO-",
          "http://localhost:8080/api/health",
        ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    networks:
      app-network:
<% if (fastifyInstances.length === 0 && expressInstances.length === 0 && fastapiInstances.length === 0 && goInstances.length === 0 && inst.path === rustInstances[0].path) { %>
        aliases:
          - backend
<% } %>
<% } %>
<% for (const inst of laravelInstances) { %>
  <%= inst.path %>:
    build:
      context: ./<%= inst.path %>
      dockerfile: Dockerfile
    expose:
      - "8000"
    env_file:
      - ./<%= inst.path %>/.env
    restart: unless-stopped
    healthcheck:
      test:
        [
          "CMD",
          "php",
          "-r",
          "exit(@file_get_contents('http://localhost:8000/api/health') === false ? 1 : 0);",
        ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    networks:
      app-network:
<% if (fastifyInstances.length === 0 && expressInstances.length === 0 && fastapiInstances.length === 0 && goInstances.length === 0 && rustInstances.length === 0 && inst.path === laravelInstances[0].path) { %>
        aliases:
          - backend
<% } %>
<% } %>
<% for (const inst of vitejsInstances) { %>
  <%= inst.path %>:
    build:
      context: ./<%= inst.path %>
      args:
        VITE_API_URL: ""
    environment:
      DOMAIN: ${DOMAIN:-localhost}
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - letsencrypt:/etc/letsencrypt
      - certbot-www:/var/www/certbot
<% if (fastifyInstances.length > 0) { %>
    depends_on:
      <%= fastifyInstances[0].path %>:
        condition: service_healthy
<% } else if (expressInstances.length > 0) { %>
    depends_on:
      <%= expressInstances[0].path %>:
        condition: service_healthy
<% } else if (fastapiInstances.length > 0) { %>
    depends_on:
      <%= fastapiInstances[0].path %>:
        condition: service_healthy
<% } else if (goInstances.length > 0) { %>
    depends_on:
      <%= goInstances[0].path %>:
        condition: service_healthy
<% } else if (rustInstances.length > 0) { %>
    depends_on:
      <%= rustInstances[0].path %>:
        condition: service_healthy
<% } else if (laravelInstances.length > 0) { %>
    depends_on:
      <%= laravelInstances[0].path %>:
        condition: service_healthy
<% } %>
    restart: unless-stopped
    healthcheck:
      test:
        [
          "CMD",
          "wget",
          "--spider",
          "-q",
          "--no-check-certificate",
          "https://127.0.0.1/",
        ]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
    networks:
      - app-network
<% } %>
<% for (const inst of nextjsInstances) { %>
  <%= inst.path %>:
    build:
      context: ./<%= inst.path %>
    environment:
      NEXT_PUBLIC_API_URL: ${NEXT_PUBLIC_API_URL:-http://localhost:8000}
    ports:
      - "3000:3000"
<% if (fastifyInstances.length > 0) { %>
    depends_on:
      <%= fastifyInstances[0].path %>:
        condition: service_healthy
<% } else if (expressInstances.length > 0) { %>
    depends_on:
      <%= expressInstances[0].path %>:
        condition: service_healthy
<% } else if (fastapiInstances.length > 0) { %>
    depends_on:
      <%= fastapiInstances[0].path %>:
        condition: service_healthy
<% } %>
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://127.0.0.1:3000/login"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s
    networks:
      - app-network
<% } %>
<% for (const inst of adminPanelInstances) { %>
  <%= inst.path %>:
    build: ./<%= inst.path %>
    expose:
      - "8055"
    env_file:
      - ./<%= inst.path %>/.env
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "/admin", "healthcheck"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
    networks:
      - app-network
<% } %>
<% if (vitejsInstances.length > 0) { %>
  certbot:
    image: certbot/certbot:latest
    volumes:
      - letsencrypt:/etc/letsencrypt
      - certbot-www:/var/www/certbot
    entrypoint: /bin/sh -c "trap exit TERM; while :; do certbot renew --quiet; sleep 12h & wait $${!}; done"
    restart: unless-stopped
    depends_on:
      <%= vitejsInstances[0].path %>:
        condition: service_healthy
    profiles:
      - ssl
    networks:
      - app-network
<% } %>
<% if (vitejsInstances.length > 0) { %>
volumes:
  letsencrypt:
  certbot-www:
<% } %>
networks:
  app-network:
    driver: bridge
