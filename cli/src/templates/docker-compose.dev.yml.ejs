services:
<% if (fastapiInstances.length > 0 || fastifyInstances.length > 0) { %>
  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: dev
      POSTGRES_PASSWORD: dev
      POSTGRES_DB: app
    ports:
      - '5432:5432'
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ['CMD-SHELL', 'pg_isready -U dev -d app']
      interval: 5s
      timeout: 3s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: '0.5'
    networks:
      - app-network
<% } %>
<% for (const inst of fastapiInstances) { %>
  <%= inst.path %>-migrate:
    build: ./<%= inst.path %>
    command: ['uv', 'run', 'migrate.py']
    environment:
      - SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://dev:dev@db:5432/app
    depends_on:
      db:
        condition: service_healthy
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: '0.5'
    networks:
      - app-network
  <%= inst.path %>:
    build: ./<%= inst.path %>
    command:
      [
        'uv', 'run', 'uvicorn', 'src.app:app',
        '--host', '0.0.0.0', '--port', '7860',
        '--workers', '2', '--timeout-keep-alive', '120', '--reload',
      ]
<% if (inst.path === inst.type) { %>
    ports:
      - '7860:7860'
<% } else { %>
    expose:
      - '7860'
<% } %>
    environment:
      - SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://dev:dev@db:5432/app
      - CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost
      - JWT_PROVIDER=shared_secret
      - JWT_SECRET=dev-secret-that-is-at-least-32-bytes-long
      - JWT_ALGORITHMS=HS256
    volumes:
      - ./<%= inst.path %>/src:/app/src
      - ./<%= inst.path %>/alembic.ini:/app/alembic.ini
      - ./<%= inst.path %>/migrate.py:/app/migrate.py
    depends_on:
      <%= inst.path %>-migrate:
        condition: service_completed_successfully
    restart: unless-stopped
    healthcheck:
      test:
        [
          'CMD', 'python', '-c',
          "import urllib.request; urllib.request.urlopen('http://localhost:7860/api/health')",
        ]
      interval: 15s
      timeout: 5s
      retries: 3
      start_period: 10s
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: '1.0'
    networks:
      - app-network
<% } %>
<% for (const inst of fastifyInstances) { %>
  <%= inst.path %>-migrate:
    build: ./<%= inst.path %>
    command: ["sh", "-c", "<%= pm.prismaExec %> migrate deploy"]
    environment:
      - DATABASE_URL=postgresql://dev:dev@db:5432/app
    depends_on:
      db:
        condition: service_healthy
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: '0.5'
    networks:
      - app-network
  <%= inst.path %>:
    build: ./<%= inst.path %>
    command: ["sh", "-c", "<%= pm.runDev %>"]
<% if (inst.path === inst.type) { %>
    ports:
      - '3000:3000'
<% } else { %>
    expose:
      - '3000'
<% } %>
    environment:
      - DATABASE_URL=postgresql://dev:dev@db:5432/app
      - CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost
      - JWT_PROVIDER=shared_secret
      - JWT_SECRET=dev-secret-that-is-at-least-32-bytes-long
    volumes:
      - ./<%= inst.path %>/src:/app/src
    depends_on:
      <%= inst.path %>-migrate:
        condition: service_completed_successfully
    restart: unless-stopped
    healthcheck:
      test: ['CMD', 'wget', '--spider', '-q', 'http://localhost:3000/api/health']
      interval: 15s
      timeout: 5s
      retries: 3
      start_period: 10s
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: '1.0'
    networks:
      - app-network
<% } %>
<% for (const inst of frontendInstances) { %>
  <%= inst.path %>:
    image: node:20-alpine
    working_dir: /app
    command: sh -c "<%= pm.install %> && <%= pm.run %> dev -- --host 0.0.0.0"
<% if (inst.path === inst.type) { %>
    ports:
      - '5173:5173'
<% } else { %>
    expose:
      - '5173'
<% } %>
    env_file:
      - ./<%= inst.path %>/.env
    volumes:
      - ./<%= inst.path %>:/app
      - <%= inst.upper.toLowerCase() %>_node_modules:/app/node_modules
<% if (fastifyInstances.length > 0) { %>
    depends_on:
      <%= fastifyInstances[0].path %>:
        condition: service_healthy
<% } else if (fastapiInstances.length > 0) { %>
    depends_on:
      <%= fastapiInstances[0].path %>:
        condition: service_healthy
<% } %>
    healthcheck:
      test: ['CMD', 'wget', '--spider', '-q', 'http://localhost:5173/']
      interval: 15s
      timeout: 5s
      retries: 3
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: '1.0'
    networks:
      - app-network
<% } %>
volumes:
<% if (fastapiInstances.length > 0 || fastifyInstances.length > 0) { %>
  pgdata:
<% } %>
<% for (const inst of frontendInstances) { %>
  <%= inst.upper.toLowerCase() %>_node_modules:
<% } %>
networks:
  app-network:
    driver: bridge
