name: CI

on:
  pull_request:
    branches: [main]
  push:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read
  pull-requests: read

env:
  WS: run-${{ github.run_id }}-${{ github.run_attempt }}

jobs:
  changes:
    name: Detect changes
    runs-on: ubuntu-latest
    outputs:
<% for (const inst of fastapiInstances) { %>
      <%= inst.path %>: ${{ steps.filter.outputs.<%= inst.path %> }}
<% } %>
<% for (const inst of fastifyInstances) { %>
      <%= inst.path %>: ${{ steps.filter.outputs.<%= inst.path %> }}
<% } %>
<% for (const inst of expressInstances) { %>
      <%= inst.path %>: ${{ steps.filter.outputs.<%= inst.path %> }}
<% } %>
<% for (const inst of goInstances) { %>
      <%= inst.path %>: ${{ steps.filter.outputs.<%= inst.path %> }}
<% } %>
<% for (const inst of rustInstances) { %>
      <%= inst.path %>: ${{ steps.filter.outputs.<%= inst.path %> }}
<% } %>
<% for (const inst of laravelInstances) { %>
      <%= inst.path %>: ${{ steps.filter.outputs.<%= inst.path %> }}
<% } %>
<% for (const inst of frontendInstances) { %>
      <%= inst.path %>: ${{ steps.filter.outputs.<%= inst.path %> }}
<% } %>
<% for (const inst of mobileInstances) { %>
      <%= inst.path %>: ${{ steps.filter.outputs.<%= inst.path %> }}
<% } %>
<% for (const inst of e2eInstances) { %>
      <%= inst.path %>: ${{ steps.filter.outputs.<%= inst.path %> }}
<% } %>
<% for (const inst of infraInstances) { %>
      <%= inst.path %>: ${{ steps.filter.outputs.<%= inst.path %> }}
<% } %>
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          path: ${{ env.WS }}
      - uses: dorny/paths-filter@d1c1ffe0248fe513906c8e24db8ea791d46f8590 # v3
        id: filter
        with:
          working-directory: ${{ env.WS }}
          filters: |
<% for (const inst of fastapiInstances) { %>
            <%= inst.path %>:
              - '<%= inst.path %>/**'
<% } %>
<% for (const inst of fastifyInstances) { %>
            <%= inst.path %>:
              - '<%= inst.path %>/**'
<% } %>
<% for (const inst of expressInstances) { %>
            <%= inst.path %>:
              - '<%= inst.path %>/**'
<% } %>
<% for (const inst of goInstances) { %>
            <%= inst.path %>:
              - '<%= inst.path %>/**'
<% } %>
<% for (const inst of rustInstances) { %>
            <%= inst.path %>:
              - '<%= inst.path %>/**'
<% } %>
<% for (const inst of laravelInstances) { %>
            <%= inst.path %>:
              - '<%= inst.path %>/**'
<% } %>
<% for (const inst of frontendInstances) { %>
            <%= inst.path %>:
              - '<%= inst.path %>/**'
<% } %>
<% for (const inst of mobileInstances) { %>
            <%= inst.path %>:
              - '<%= inst.path %>/**'
<% } %>
<% for (const inst of e2eInstances) { %>
            <%= inst.path %>:
              - '<%= inst.path %>/**'
<% } %>
<% for (const inst of infraInstances) { %>
            <%= inst.path %>:
              - '<%= inst.path %>/**'
<% } %>

  secrets:
    name: Secret scan
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          fetch-depth: 0
          path: ${{ env.WS }}
      - name: Install gitleaks
        run: |
          curl -sSL -o /tmp/gitleaks.tar.gz https://github.com/gitleaks/gitleaks/releases/download/v8.21.2/gitleaks_8.21.2_linux_x64.tar.gz
          tar -xzf /tmp/gitleaks.tar.gz -C /tmp gitleaks
          sudo mv /tmp/gitleaks /usr/local/bin/gitleaks
      - name: Run gitleaks
        run: gitleaks detect --source ${{ env.WS }} --no-git --no-banner --redact --exit-code 1
      - run: python3 ${{ env.WS }}/scripts/style-check.py ${{ env.WS }}/frontend/src
<% for (const inst of fastapiInstances) { %>

  <%= inst.path %>:
    name: <%= inst.display %> (format + lint + typecheck + audit)
    needs: changes
    if: github.event_name == 'workflow_dispatch' || needs.changes.outputs.<%= inst.path %> == 'true'
    runs-on: ubuntu-latest
    services:
      postgres:
        image: postgres:16
        env:
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: postgres
          POSTGRES_DB: ci_test
        ports:
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 5s
          --health-timeout 5s
          --health-retries 5
    defaults:
      run:
        working-directory: ${{ env.WS }}/<%= inst.path %>
    env:
      SQLALCHEMY_DATABASE_URI: postgresql+asyncpg://postgres:postgres@localhost:5432/ci_test
      JWT_PROVIDER: shared_secret
      JWT_SECRET: ci-test-secret # gitleaks:allow
      JWT_ALGORITHMS: HS256
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          path: ${{ env.WS }}
      - uses: astral-sh/setup-uv@38f3f104447c67c051c4a08e39b64a148898af3a # v4
      - run: uv sync --group dev
      - run: uv run ruff format --check src tests
      - run: uv run ruff check src tests
      - run: uv run mypy
      - name: Audit Python dependencies
        run: |
          run_pip_audit() {
            for attempt in 1 2 3; do
              if bash audit.sh; then
                return 0
              fi
              if [ "$attempt" -eq 3 ]; then
                return 1
              fi
              sleep $((attempt * 5))
            done
          }
          run_pip_audit
<% } %>
<% for (const inst of fastifyInstances) { %>

  <%= inst.path %>:
    name: <%= inst.display %> (format + lint + typecheck + build + audit)
    needs: changes
    if: github.event_name == 'workflow_dispatch' || needs.changes.outputs.<%= inst.path %> == 'true'
    runs-on: ubuntu-latest
    services:
      postgres:
        image: postgres:16
        env:
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: postgres
          POSTGRES_DB: ci_test
        ports:
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 5s
          --health-timeout 5s
          --health-retries 5
    defaults:
      run:
        working-directory: ${{ env.WS }}/<%= inst.path %>
    env:
      DATABASE_URL: postgresql://postgres:postgres@localhost:5432/ci_test
      JWT_SECRET: ci-test-secret # gitleaks:allow
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          path: ${{ env.WS }}
<% if (pm.name === 'pnpm') { %>
      - uses: pnpm/action-setup@b906affcce14559ad1aafd4ab0e942779e9f58b1 # v4
        with:
          version: 10
<% } %>
<% if (pm.name === 'bun') { %>
      - uses: oven-sh/setup-bun@0c5077e51419868618aeaa5fe8019c62421857d6 # v2
<% } %>
<% if (pm.name !== 'bun') { %>
      - uses: actions/setup-node@a0853c24544627f65ddf259abe73b1d18a591444 # v5
        with:
          node-version: 22
          cache: <%= pm.name %>
          cache-dependency-path: ${{ env.WS }}/<%= inst.path %>/<%= pm.lockfile %>
<% } %>
      - run: <%= pm.ci %>
<% if (orm === 'drizzle') { %>
      - run: <%= pm.exec %> drizzle-kit push --force
<% } else if (orm === 'sequelize' || orm === 'typeorm') { %>
      - run: <%= pm.exec %> tsx scripts/db-sync.ts
<% } else { %>
      - run: <%= pm.prismaExec %> generate
      - run: <%= pm.prismaExec %> migrate deploy
<% } %>
      - run: <%= pm.exec %> prettier --check .
      - run: <%= pm.exec %> eslint .
      - run: <%= pm.exec %> tsc --noEmit
      - run: <%= pm.run %> build
      - run: <%= pm.audit %>
<% } %>
<% for (const inst of expressInstances) { %>

  <%= inst.path %>:
    name: <%= inst.display %> (format + lint + typecheck + build + audit)
    needs: changes
    if: github.event_name == 'workflow_dispatch' || needs.changes.outputs.<%= inst.path %> == 'true'
    runs-on: ubuntu-latest
    services:
      postgres:
        image: postgres:16
        env:
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: postgres
          POSTGRES_DB: ci_test
        ports:
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 5s
          --health-timeout 5s
          --health-retries 5
    defaults:
      run:
        working-directory: ${{ env.WS }}/<%= inst.path %>
    env:
      DATABASE_URL: postgresql://postgres:postgres@localhost:5432/ci_test
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          path: ${{ env.WS }}
<% if (pm.name === 'pnpm') { %>
      - uses: pnpm/action-setup@b906affcce14559ad1aafd4ab0e942779e9f58b1 # v4
        with:
          version: 10
<% } %>
<% if (pm.name === 'bun') { %>
      - uses: oven-sh/setup-bun@0c5077e51419868618aeaa5fe8019c62421857d6 # v2
<% } %>
<% if (pm.name !== 'bun') { %>
      - uses: actions/setup-node@a0853c24544627f65ddf259abe73b1d18a591444 # v5
        with:
          node-version: 22
          cache: <%= pm.name %>
          cache-dependency-path: ${{ env.WS }}/<%= inst.path %>/<%= pm.lockfile %>
<% } %>
      - run: <%= pm.ci %>
<% if (orm === 'drizzle') { %>
      - run: <%= pm.exec %> drizzle-kit push --force
<% } else if (orm === 'sequelize' || orm === 'typeorm') { %>
      - run: <%= pm.exec %> tsx scripts/db-sync.ts
<% } else { %>
      - run: <%= pm.prismaExec %> generate
      - run: <%= pm.prismaExec %> migrate deploy
<% } %>
      - run: <%= pm.exec %> prettier --check .
      - run: <%= pm.exec %> eslint .
      - run: <%= pm.exec %> tsc --noEmit
      - run: <%= pm.run %> build
      - run: <%= pm.audit %>
<% } %>
<% for (const inst of goInstances) { %>

  <%= inst.path %>:
    name: <%= inst.display %> (format + vet + lint + build + test + audit)
    needs: changes
    if: github.event_name == 'workflow_dispatch' || needs.changes.outputs.<%= inst.path %> == 'true'
    runs-on: ubuntu-latest
    services:
      postgres:
        image: postgres:16
        env:
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: postgres
          POSTGRES_DB: ci_test
        ports:
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 5s
          --health-timeout 5s
          --health-retries 5
    defaults:
      run:
        working-directory: ${{ env.WS }}/<%= inst.path %>
    env:
      DATABASE_URL: postgresql://postgres:postgres@localhost:5432/ci_test
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          path: ${{ env.WS }}
      - uses: actions/setup-go@d35c59abb061a4a6fb18e82ac0862c26744d6ab5 # v5
        with:
          go-version-file: ${{ env.WS }}/<%= inst.path %>/go.mod
          cache-dependency-path: ${{ env.WS }}/<%= inst.path %>/go.sum
      - run: go mod download
<% if (orm === 'sqlc') { %>
      - name: Install sqlc
        run: go install github.com/sqlc-dev/sqlc/cmd/sqlc@v1.27.0
      - name: sqlc generate --check (drift gate)
        run: "$(go env GOPATH)/bin/sqlc generate --check"
<% } else if (orm === 'ent') { %>
      - name: ent generate (drift gate)
        run: |
          go generate ./ent/...
          if ! git diff --quiet; then
            echo "::error::ent generate produced uncommitted drift:"
            git diff --stat
            exit 1
          fi
<% } %>
      - name: gofmt
        run: |
          out="$(gofmt -l .)"
          if [ -n "$out" ]; then
            echo "::error::gofmt found unformatted files:"
            echo "$out"
            exit 1
          fi
      - run: go vet ./...
      - run: go build ./...
      - uses: golangci/golangci-lint-action@9fae48acfc02a90574d7c304a1758ef9895495fa # v7
        with:
          version: v2.12.2
          working-directory: ${{ env.WS }}/<%= inst.path %>
      - name: govulncheck
        run: |
          go install golang.org/x/vuln/cmd/govulncheck@v1.1.4
          "$(go env GOPATH)/bin/govulncheck" ./...
      - run: go test -race -coverprofile=coverage.out ./...
      - run: bash scripts/check-coverage.sh
<% } %>
<% for (const inst of rustInstances) { %>

  <%= inst.path %>:
    name: <%= inst.display %> (fmt + clippy + test + coverage)
    needs: changes
    if: github.event_name == 'workflow_dispatch' || needs.changes.outputs.<%= inst.path %> == 'true'
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: ${{ env.WS }}/<%= inst.path %>
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          path: ${{ env.WS }}
      - uses: dtolnay/rust-toolchain@29eef336d9b2848a0b548edc03f92a220660cdb8 # stable
        with:
          toolchain: '1.83'
          components: rustfmt, clippy
      - run: cargo fmt --check
      - run: cargo clippy -- -D warnings
      - run: cargo test --all-features
      - name: Install cargo-tarpaulin
        run: cargo install cargo-tarpaulin --version 0.31.5 --locked
      - name: Coverage (≥80%)
        run: cargo tarpaulin --fail-under 80 --out Xml --workspace --all-features
<% } %>
<% for (const inst of laravelInstances) { %>

  <%= inst.path %>:
    name: <%= inst.display %> (pint + phpstan + pest + coverage)
    needs: changes
    if: github.event_name == 'workflow_dispatch' || needs.changes.outputs.<%= inst.path %> == 'true'
    runs-on: ubuntu-latest
    services:
      postgres:
        image: postgres:16
        env:
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: postgres
          POSTGRES_DB: ci_test
        ports:
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 5s
          --health-timeout 5s
          --health-retries 5
    env:
      DB_CONNECTION: pgsql
      DB_HOST: localhost
      DB_PORT: 5432
      DB_DATABASE: ci_test
      DB_USERNAME: postgres
      DB_PASSWORD: postgres
    defaults:
      run:
        working-directory: ${{ env.WS }}/<%= inst.path %>
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          path: ${{ env.WS }}
      - uses: shivammathur/setup-php@7c071dfe9dc99bdf297fa79cb49ea005b9fcadbc # v2.37.1
        with:
          php-version: '8.3'
          extensions: pdo_pgsql,pcntl,bcmath,intl
          coverage: pcov
      - run: composer install --no-interaction --prefer-dist
      - run: ./vendor/bin/pint --test
      - run: ./vendor/bin/phpstan analyse --no-progress --level=8
      - run: ./vendor/bin/pest --coverage --min=80
<% } %>
<% for (const inst of frontendInstances) { %>

  <%= inst.path %>:
    name: <%= inst.display %> (format + lint + typecheck + build + audit)
    needs: changes
    if: github.event_name == 'workflow_dispatch' || needs.changes.outputs.<%= inst.path %> == 'true'
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: ${{ env.WS }}/<%= inst.path %>
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          path: ${{ env.WS }}
<% if (pm.name === 'pnpm') { %>
      - uses: pnpm/action-setup@b906affcce14559ad1aafd4ab0e942779e9f58b1 # v4
        with:
          version: 10
<% } %>
<% if (pm.name === 'bun') { %>
      - uses: oven-sh/setup-bun@0c5077e51419868618aeaa5fe8019c62421857d6 # v2
<% } %>
<% if (pm.name !== 'bun') { %>
      - uses: actions/setup-node@a0853c24544627f65ddf259abe73b1d18a591444 # v5
        with:
          node-version: 22
          cache: <%= pm.name %>
          cache-dependency-path: ${{ env.WS }}/<%= inst.path %>/<%= pm.lockfile %>
<% } %>
      - run: <%= pm.ci %>
      - run: <%= pm.exec %> prettier --check .
      - run: <%= pm.exec %> eslint 'src/**/*.{ts,tsx}'
      - run: <%= pm.exec %> tsc --noEmit
      - run: <%= pm.run %> build
      - run: bash scripts/check-bundle-size.sh
      # Validates frontend/nginx.conf against the same nginx image the Dockerfile
      # uses. Catches unknown / module-dependent directives (e.g. `brotli on;` on
      # stock nginx:alpine) BEFORE deploy — without it, the directive only fails
      # when the container tries to start in prod, after CI is green.
      #
      # GOTCHA: if you convert this job to self-hosted runners (shared outbound
      # IP), `docker run` against `public.ecr.aws/...` will fall back to anonymous
      # pulls and hit rate limits across concurrent runs. Add OIDC + ECR Public
      # login steps before this step (see memoria/.github/workflows/ci.yml).
      - name: Validate nginx config against runtime image
        working-directory: ${{ env.WS }}
        run: bash scripts/validate-nginx-config.sh
<% } %>
<% for (const inst of mobileInstances) { %>

  <%= inst.path %>:
    name: <%= inst.display %> (format + analyze + test + coverage)
    needs: changes
    if: github.event_name == 'workflow_dispatch' || needs.changes.outputs.<%= inst.path %> == 'true'
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: ${{ env.WS }}/<%= inst.path %>
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          path: ${{ env.WS }}
      - uses: subosito/flutter-action@1a449444c387b1966244ae4d4f8c696479add0b2 # v2
        with:
          channel: stable
      - run: flutter pub get
      - run: dart run build_runner build --delete-conflicting-outputs
      - run: dart format --set-exit-if-changed .
      - run: dart analyze --fatal-infos
      - run: flutter test --coverage
      - run: bash scripts/check-coverage.sh
<% } %>
<% for (const inst of e2eInstances) { %>

  <%= inst.path %>:
    name: <%= inst.display %> (format + lint + typecheck + audit)
    needs: changes
    if: github.event_name == 'workflow_dispatch' || needs.changes.outputs.<%= inst.path %> == 'true'
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: ${{ env.WS }}/<%= inst.path %>
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          path: ${{ env.WS }}
<% if (pm.name === 'pnpm') { %>
      - uses: pnpm/action-setup@b906affcce14559ad1aafd4ab0e942779e9f58b1 # v4
        with:
          version: 10
<% } %>
<% if (pm.name === 'bun') { %>
      - uses: oven-sh/setup-bun@0c5077e51419868618aeaa5fe8019c62421857d6 # v2
<% } %>
<% if (pm.name !== 'bun') { %>
      - uses: actions/setup-node@a0853c24544627f65ddf259abe73b1d18a591444 # v5
        with:
          node-version: 22
          cache: <%= pm.name %>
          cache-dependency-path: ${{ env.WS }}/<%= inst.path %>/<%= pm.lockfile %>
<% } %>
      - run: <%= pm.ci %>
      - run: <%= pm.exec %> prettier --check .
      - run: <%= pm.exec %> eslint '**/*.ts'
      - run: <%= pm.exec %> tsc --noEmit
      - run: <%= pm.audit %>
<% } %>
<% for (const inst of infraInstances) { %>

  <%= inst.path %>:
    name: <%= inst.display %> (fmt + validate)
    needs: changes
    if: github.event_name == 'workflow_dispatch' || needs.changes.outputs.<%= inst.path %> == 'true'
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: ${{ env.WS }}/<%= inst.path %>/stack
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          path: ${{ env.WS }}
      - uses: hashicorp/setup-terraform@b9cd54a3c349d3f38e8881555d616ced269862dd # v3
        with:
          terraform_version: '1.11'
      - run: terraform fmt -check -recursive
      - run: terraform init -backend=false
      - run: terraform validate
<% } %>
