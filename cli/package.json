{
  "name": "create-projx",
  "version": "1.7.0",
  "description": "Scaffold production-grade fullstack projects in seconds. FastAPI, Fastify, Express, React, Flutter, Terraform — with auth, database, CI/CD, E2E tests, and Docker. One command, ready to deploy.",
  "type": "module",
  "bin": {
    "create-projx": "dist/index.js"
  },
  "files": [
    "dist",
    "src/templates",
    "src/addons"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node18 --clean",
    "dev": "tsup src/index.ts --format esm --target node18 --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "projx",
    "scaffold",
    "template",
    "boilerplate",
    "starter-kit",
    "project-generator",
    "fullstack",
    "fastapi",
    "fastify",
    "express",
    "react",
    "flutter",
    "terraform",
    "docker",
    "typescript",
    "create",
    "cli",
    "monorepo",
    "scaffolding"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ukanhaupa/projx.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/ukanhaupa/projx#readme",
  "bugs": {
    "url": "https://github.com/ukanhaupa/projx/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.0",
    "prettier": "^3.8.3",
    "tsup": "^8",
    "typescript": "^5",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
