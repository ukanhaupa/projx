{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": false,
    "types": ["node"]
  },
  "include": ["src", "tests"],
  "exclude": ["src/addons", "node_modules", "dist"]
}
