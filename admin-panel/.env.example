DATABASE_URL=postgres://postgres:postgres@postgres:5432/app?sslmode=disable

SESSION_SECRET=<generate: openssl rand -hex 32>

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<set-a-strong-password>

PORT=8055
BASE_PATH=/admin

# Session cookies are Secure by default; set to false only when serving over plain HTTP.
COOKIE_SECURE=true

# Optional, bootstrap-only. Base64 of exactly 32 bytes; must equal the backend's CRED_ENCRYPTION_KEY.
# Enables the per-value Decrypt action on encrypted service_configs.config (write-mode admins only).
# CRED_ENCRYPTION_KEY=<generate: openssl rand -base64 32>
