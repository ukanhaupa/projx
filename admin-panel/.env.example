DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=directus
DB_USER=postgres
DB_PASSWORD=postgres

# 32-byte random key for cookie/JWT signing.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEY=<generate-with-above-command>

# 32-byte random secret for access-token signing.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET=<generate-with-above-command>

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<set-a-strong-password>

# Served behind the frontend nginx at /admin/. Set to the full external URL in production.
PUBLIC_URL=/admin
