{
  "name": "projx-express",
  "version": "1.0.0",
  "description": "Express backend template with TypeScript, Prisma, auto-entity CRUD, security middleware, health checks, and tests",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=.env dist/server.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --fix src/ tests/",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@sentry/node": "^10.57.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.13.1",
    "pino-http": "^11.0.0",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.6.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "prisma": "^6.19.0",
    "supertest": "^7.1.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "@opentelemetry/core@<2.8.0": ">=2.8.0",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2"
    }
  }
}
