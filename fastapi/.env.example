SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://user:pass@localhost:5432/mydb
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173

# 48+ byte secret for JWT signing/verification.
# Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=<generate-with-above-command>

# 32-byte base64 key for encrypting credentials in service_configs.
# Generate: python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
CRED_ENCRYPTION_KEY=<generate-with-above-command>
