APP_ENV=test
# Test database — defaults to sqlite-in-memory for fast local runs.
# Switch to Postgres (testcontainers, docker-compose, or hosted) by setting:
#   SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://user:pass@localhost:5433/test_db
SQLALCHEMY_DATABASE_URI=sqlite+aiosqlite:///:memory:
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1
AUTH_ENABLED=true
SYNC_WORKER_CONCURRENCY=2
PYTHONUNBUFFERED=1
JWT_PROVIDER=shared_secret
JWT_SECRET=test-secret-that-is-at-least-32-bytes-long
JWT_ALGORITHMS=HS256
JWT_ISSUER=
JWT_AUDIENCE=
JWT_REQUIRE_EXP=true
JWT_VERIFY_NBF=true
JWT_VERIFY_IAT=false
