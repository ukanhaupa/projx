# Copy this file to .env.dev, .env.staging, or .env.prod and fill in the values.
# These files are gitignored — never commit real credentials.

# ── AWS credentials (non-console IAM user) ───────────────────────────────────
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>
AWS_SESSION_TOKEN=                        # optional — for temporary session credentials
AWS_REGION=us-east-1                      # region to deploy into (bin/tf auto-propagates to TF_VAR_aws_region)

# ── Project identity ──────────────────────────────────────────────────────────
TF_VAR_project=my-project                 # used as prefix for all resource names

# ── Deployment mode ───────────────────────────────────────────────────────────
TF_VAR_deployment_mode=k8s                # 'k8s' (EKS) or 'compose' (EC2 + Docker)

# ── Feature toggles ───────────────────────────────────────────────────────────
TF_VAR_enable_keycloak=true               # deploy Keycloak identity provider
TF_VAR_cicd_enabled=true                  # deploy CodePipeline + CodeBuild + ECR

# ── Network access ────────────────────────────────────────────────────────────
# EKS API endpoint access (k8s mode). Use ["0.0.0.0/0"] for dev, restrict for prod.
TF_VAR_public_access_cidrs='["YOUR_IP/32"]'
# Direct DB access (dev only, requires db_publicly_accessible=true in tfvars)
TF_VAR_db_public_access_cidrs='["YOUR_IP/32"]'

# ── Secrets (required — never commit real values) ─────────────────────────────
TF_VAR_keycloak_client_secret=<strong-random-secret>
TF_VAR_db_reader_password=<strong-random-password>
TF_VAR_backend_db_password=<strong-random-password>

# ── Optional overrides (defaults derived from TF_VAR_project) ─────────────────
# TF_VAR_aws_account_id=         # override auto-detected AWS account ID
# TF_VAR_keycloak_realm_name=    # default: <project>-<environment>
# TF_VAR_keycloak_client_id=     # default: <project>-backend
# TF_VAR_backend_db_name=        # default: <project> with hyphens→underscores
# TF_VAR_cicd_codecommit_repository_name=  # default: <project>
# TF_VAR_backend_cors_allow_origins=https://app.example.com  # default: * — MUST restrict for prod
